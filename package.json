{
  "name": "ai-workspace-archive-pad",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "extension",
    "backend",
    "website"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "assets:store": "node scripts/generate-store-assets.cjs",
    "package:extension": "node scripts/package-extension.cjs",
    "qa:extension": "node scripts/qa-extension.cjs",
    "qa:live-parsers": "node scripts/live-parser-qa.cjs",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "check": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "playwright": "^1.58.2",
    "typescript": "^6.0.2"
  }
}
